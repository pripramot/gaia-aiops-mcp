# GTSAlpha Forensics MCP Server — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────
PORT=3890
NODE_ENV=production
ALLOWED_ORIGINS=https://gh-unicorn.netlify.app,http://localhost:5173

# ── Database: Supabase (ใช้ DATABASE_URL เดียวแทน individual vars) ──
# ดู connection string ได้ที่: Supabase Dashboard → Project Settings → Database → URI
# ใช้ "Transaction pooler" port 6543 สำหรับ production (รองรับ serverless/container)
DATABASE_URL=postgresql://postgres.hkkddlxhcttnejlblmsc:[DB_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Database (fallback — ใช้ถ้าไม่มี DATABASE_URL) ──────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=gtsalpha_forensics
# DB_USER=gtsalpha
# DB_PASSWORD=CHANGE_ME
# DB_SSL=false

# ── JWT ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_64_BYTE_RANDOM_HEX
JWT_EXPIRES_IN=8h
REFRESH_EXPIRES=7d

# ── HMAC Signature (evidence integrity) ────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=CHANGE_ME_USE_32_BYTE_RANDOM_HEX

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

